[configuration]
entry_symbol = "rmlui_godot_init"
compatibility_minimum = 4.2

[libraries]
windows.debug.x86_64 = "res://addons/rmlui-godot/bin/rmlui_godot.debug.dll"
windows.release.x86_64 = "res://addons/rmlui-godot/bin/rmlui_godot.release.dll"
linux.debug.x86_64 = "res://addons/rmlui-godot/bin/rmlui_godot.debug.so"
linux.release.x86_64 = "res://addons/rmlui-godot/bin/rmlui_godot.release.so"
macos.debug = "res://addons/rmlui-godot/bin/rmlui_godot.debug.dylib"
macos.release = "res://addons/rmlui-godot/bin/rmlui_godot.release.dylib"
